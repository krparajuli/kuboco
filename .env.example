# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-use-openssl-rand-hex-32

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

DATABASE_URL=sqlite+aiosqlite:///./kuboco.db

CONTAINER_IMAGE=kuboco/ubuntu-ttyd:latest
CONTAINER_NAMESPACE=kuboco-containers
BACKEND_NAMESPACE=kuboco

POD_CPU_LIMIT=1
POD_MEMORY_LIMIT=1Gi
POD_CPU_REQUEST=100m
POD_MEMORY_REQUEST=128Mi

TTYD_PORT=7681
MAX_CONTAINERS_PER_USER=5

# Leave unset for in-cluster auth; set path for local dev
# KUBECONFIG_PATH=/home/user/.kube/config
